{
  "name": "@contextoptimizer/parser",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run --passWithNoTests src",
    "lint": "biome check src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contextoptimizer/core": "workspace:*",
    "tree-sitter": "^0.22.4",
    "tree-sitter-c": "^0.23.4",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.23.4",
    "tree-sitter-java": "^0.23.4",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-python": "^0.23.4",
    "tree-sitter-rust": "^0.23.2",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "description": "tree-sitter parser for ContextOptimizer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contextoptimizer/contextoptimizer.git",
    "directory": "packages/parser"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  }
}
