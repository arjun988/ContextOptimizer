{
  "name": "@contextoptimizer/engine",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run --passWithNoTests src",
    "lint": "biome check src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contextoptimizer/cache": "workspace:*",
    "@contextoptimizer/compression": "workspace:*",
    "@contextoptimizer/core": "workspace:*",
    "@contextoptimizer/embeddings": "workspace:*",
    "@contextoptimizer/graph": "workspace:*",
    "@contextoptimizer/indexer": "workspace:*",
    "@contextoptimizer/memory": "workspace:*",
    "@contextoptimizer/observability": "workspace:*",
    "@contextoptimizer/parser": "workspace:*",
    "@contextoptimizer/ranking": "workspace:*",
    "@contextoptimizer/retrieval": "workspace:*",
    "@contextoptimizer/storage": "workspace:*",
    "@contextoptimizer/tokenizer": "workspace:*",
    "@contextoptimizer/vector-store": "workspace:*"
  },
  "devDependencies": { "tsup": "^8.3.5", "typescript": "^5.7.2" }
}
