{
  "name": "@contextoptimizer/api",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": { "contextoptimizer-api": "./dist/index.js" },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests src",
    "lint": "biome check src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contextoptimizer/core": "workspace:*",
    "@contextoptimizer/embeddings": "workspace:*",
    "@contextoptimizer/engine": "workspace:*",
    "@contextoptimizer/observability": "workspace:*",
    "@contextoptimizer/storage-postgres": "workspace:*",
    "@contextoptimizer/vector-store": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "fastify": "^5.2.1"
  },
  "devDependencies": { "tsup": "^8.3.5", "typescript": "^5.7.2" }
}
